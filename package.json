{
  "name": "shape-craft",
  "private": true,
  "version": "0.1.0",
  "description": "AI-driven UGC 3D world & multiplayer game creation platform (phase 1: asset/component library + editor)",
  "scripts": {
    "dev": "pnpm --filter @shape-craft/web dev",
    "dev:api": "pnpm --filter @shape-craft/api dev",
    "build": "pnpm --filter @shape-craft/web build",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20.19"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
